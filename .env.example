# Webhook URLs for form submissions (server-side only, never exposed to client)
# Configure these in Vercel Dashboard > Settings > Environment Variables
WEBHOOK_CONTACT="https://your-webhook-url-for-contact-form"
WEBHOOK_NEWSLETTER="https://your-webhook-url-for-newsletter"

# Allowed origins for CSRF protection (comma-separated)
# Example: https://alpha-i.fr,https://www.alpha-i.fr
ALLOWED_ORIGINS="https://your-domain.com"
